{
  "version": 2,
  "functions": {
    "api/server.ts": {
      "maxDuration": 30
    }
  },
  "buildCommand": "NODE_ENV=production vite build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}