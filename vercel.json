{
  "version": 2,
  "buildCommand": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=api/index.js",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}