{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "public/capaian_pembelajaran/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/|capaian_pembelajaran/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
