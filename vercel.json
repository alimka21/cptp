{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": [
        "capaian_pembelajaran/**",
        "server/templates/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
