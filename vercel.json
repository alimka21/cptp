{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "capaian_pembelajaran/**"
    },
    "api/index.ts": {
      "includeFiles": "capaian_pembelajaran/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
